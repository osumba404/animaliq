APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# MAIL_MAILER=log
# MAIL_SCHEME=null
# MAIL_HOST=127.0.0.1
# MAIL_PORT=2525
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_FROM_ADDRESS="hello@example.com"
# MAIL_FROM_NAME="${APP_NAME}"

MAIL_MAILER=smtp
MAIL_HOST=mail.animaliq.co.ke
MAIL_PORT=465
MAIL_SCHEME=smtps
MAIL_VERIFY_PEER=false
MAIL_USERNAME=notification@animaliq.co.ke
MAIL_PASSWORD=@animaliq.co.ke
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="notification@animaliq.co.ke"
MAIL_FROM_NAME="Animal IQ Initiative"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# M-Pesa Daraja API (not implemented yet – placeholders for future integration)
# ---------------------------------------------------------------------------
# Get credentials from https://developer.safaricom.co.ke (sandbox or production).
# MPESA_CALLBACK_BASE_URL must be the public base URL Safaricom can reach (e.g. https://yourdomain.com).
# MPESA_STK_CALLBACK_PATH is the path appended to MPESA_CALLBACK_BASE_URL for STK Push result callbacks.
# MPESA_ENV=sandbox
# MPESA_CONSUMER_KEY=
# MPESA_CONSUMER_SECRET=
# MPESA_SHORTCODE=
# MPESA_PASSKEY=
# MPESA_CALLBACK_BASE_URL="${APP_URL}"
# MPESA_STK_CALLBACK_PATH=api/mpesa/stk-callback
# MPESA_ACCOUNT_REFERENCE=AnimalIQ
# MPESA_TIMEOUT=30
# MPESA_QUEUE_CALLBACK=false

